DAY 26 - Programs for List and Dictionary Comprehension

--Using dictionary comprehension.py
students = {101:"Rajeev Mehra", 102:"Mahima Gupta"}
print(students) 
   
reverse_students = { name : roll_number for roll_number, name in students.items()}
    
print(reverse_students)

-- using list comprehension.py
numbers = [4, 1, 3, 2, 5]
print(numbers)

square_numbers = [ n ** 2 for n in numbers]
print(square_numbers)

-- Without dictionary comprehnsion.py
students = {101:"Rajeev Mehra", 102:"Mahima Gupta"}
print(students)
print(students.items())

for x in students.items():
    print(x)
    
for x, y in students.items():
    print(x, y)
    
reverse_students = {}
for roll_number, name in students.items():
    reverse_students[name] = roll_number
    
print(reverse_students)

-- Without list comprehension.py
numbers = [4, 1, 3, 2, 5]
print(numbers)

square_numbers = []

for n in numbers:
    square_numbers.append(n ** 2)
    
print(square_numbers)

for n in square_numbers:
    print(n)
