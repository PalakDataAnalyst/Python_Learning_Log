-- Set keyboard input.py
roll_numbers = set()
print(type(roll_numbers))
print(roll_numbers)

while True:
    rno = int(input("Enter roll number: "))
    roll_numbers.add(rno)
    print(roll_numbers)
    
    choice = input("Do you want to add another roll number?[Yes/No]: ")
    if choice.lower() == "no":
        break


-- Set keyboard input2.py
roll_numbers = set()
print(type(roll_numbers))
print(roll_numbers)

while True:
    rno = int(input("Enter roll number: "))
    if rno not in roll_numbers:
        roll_numbers.add(rno)
        print(rno, "roll number is added successfully")
    else:
        print(rno, "is already added")
    print(roll_numbers)
    
    choice = input("Do you want to add another roll number?[Yes/No]: ")
    if choice.lower() == "no":
        break

