--Keyword Argument function.py
def display(name, age):
    print("Name:", name)
    print("Age:", age)
    
display("Vijay Verma", 23) #Value based argument passing
display(name="Manoj Pandey", age=24) #Keyword based argument passing
display(23, 'Roshini Mishra') #Value based argument passing
display(age=23, name="Roshini Mishra") #Keyword based argument passing

--Keyword Variable Argument Function Use.py
def add(**numbers):
    s = sum(numbers.values())
    return s
    
print(add(n1 = 10, n2 = 20, n3 = 30))
print(add(n1 = 10, n2 = 30))

--Keyword Variable Argument Function Use.py
def display(**kwargs):
    print(type(kwargs))
    print(kwargs)
    
display(name = "Vijay Mehra", age = 23, city = 'Greater Noida')
display(name = 'Mahima Gupta', age = 22)
display(name = "Pankaj Mishra", age = 24, city = "New Delhi", phone_number = '+91-9811234522')

